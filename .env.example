# AgentKit — Variables de entorno
# Copia este archivo como .env y llena tus datos:
#   cp .env.example .env
#
# Claude Code te ayuda a llenar estos valores durante el setup.
# NUNCA subas el archivo .env a GitHub.

# ── Gemini API (usado por el cerebro del agente) ─────────────────
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Proveedor de IA ─────────────────────────────────────
# Ahora usamos OpenCode Go (suscripción de bajo costo) en lugar de Gemini.
# $5 primer mes, luego $10/mes. Modelo por defecto: deepseek-v4-flash.
# Más info: https://opencode.ai/docs/es/go/
OPENCODE_API_KEY=sk-...
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_MODEL=deepseek-v4-flash

# ── Proveedor de WhatsApp ─────────────────────────────
# Opciones: twilio
WHATSAPP_PROVIDER=twilio

# ── Twilio (si WHATSAPP_PROVIDER=twilio) ───────────────────
# Configurar en: https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Servidor ───────────────────────────────────────
PORT=8000
ENVIRONMENT=development  # development | production

# ── Base de datos ──────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Produccion (PostgreSQL en Railway):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── Integración de Google (Reservas) ────────────────────
# ID del spreadsheet de Google Sheets (lo que aparece en la URL)
GOOGLE_SHEET_ID=
# ID del calendario de Google Calendar (ej: tu-correo@gmail.com)
GOOGLE_CALENDAR_ID=

# ★ MÉTODO RECOMENDADO: Service Account (nunca expira)
# 1. Ve a Google Cloud Console → IAM → Service Accounts
# 2. Crea una cuenta de servicio y descarga la clave JSON
# 3. Comparte tu Google Sheet y Calendar con el email de la cuenta de servicio
# 4. Pega el JSON completo (en una línea) aquí:
# GOOGLE_SERVICE_ACCOUNT_JSON={"toke...."]

# ★ Alternativa: OAuth2 Desktop (puede expirar cada 7 días en testing)
# GOOGLE_CREDENTIALS_JSON={"toke.....]...

# ── Credenciales alternativas de Google (solo desarrollo local) ──────
# Estos archivos están en .gitignore y NO se suben a GitHub.
# Coloca los archivos en la carpeta config/ en tu máquina local.
# config/client_secret.json
# config/token.json